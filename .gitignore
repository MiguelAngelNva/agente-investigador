# --- Python & Entorno Virtual ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
build/
dist/
*.egg-info/

# --- Configuración y Secretos (CRÍTICO) ---
.env
.env.local
.env.development
.env.production
*.json
!app/services/agents/prompts/*.yaml  # Permitir los prompts pero no las llaves

# --- Google Cloud & Firebase ---
